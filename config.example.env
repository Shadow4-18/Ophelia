# ~/.ophelia/.env — The Ophelia Project

# --- Provider routing (local-first default) ---
# Values: auto | ollama | xai-oauth | xai | openai | compat
OPHELIA_PROVIDER=ollama

# Optional per-role provider overrides (each role can use a different provider)
# OPHELIA_PROVIDER_CHAT=ollama
# OPHELIA_PROVIDER_CONSCIOUSNESS=ollama
# OPHELIA_PROVIDER_VISION=ollama
# OPHELIA_PROVIDER_CURATOR=ollama
# OPHELIA_PROVIDER_IMAGE=xai-oauth
# OPHELIA_PROVIDER_VIDEO=xai-oauth
# OPHELIA_AUTO_LOCAL_CONSCIOUSNESS=true

# Optional per-role MODEL overrides (when unset, optional roles inherit chat)
# Ollama per-role:
# OLLAMA_CONSCIOUSNESS_MODEL=llama3.2:1b
# OLLAMA_CURATOR_MODEL=llama3.2:3b
# OLLAMA_VISION_MODEL=llava:7b
# OLLAMA_IMAGE_MODEL=flux
# xAI per-role:
# XAI_CONSCIOUSNESS_MODEL=grok-3-mini
# XAI_CURATOR_MODEL=grok-3-mini
# XAI_VISION_MODEL=grok-4
# XAI_IMAGE_MODEL=grok-imagine-image
# XAI_VIDEO_MODEL=grok-imagine-video
# OpenAI per-role:
# OPENAI_CONSCIOUSNESS_MODEL=gpt-4o-mini
# OPENAI_CURATOR_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# Compat per-role:
# OPHELIA_COMPAT_CONSCIOUSNESS_MODEL=local-small
# OPHELIA_COMPAT_CURATOR_MODEL=local-small
# OPHELIA_COMPAT_VISION_MODEL=local-vision

# --- Ollama (local — recommended) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:7b

# --- xAI / SuperGrok OAuth (optional cloud fallback) ---
# ophelia auth import-hermes  OR  ophelia auth import-grok
# OPHELIA_PROVIDER=xai-oauth
# XAI_API_KEY=xai-...
XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1

# --- OpenAI / compat ---
# OPENAI_API_KEY=sk-...
# OPHELIA_COMPAT_API_KEY=...
# OPHELIA_COMPAT_BASE_URL=http://127.0.0.1:1234/v1
# OPHELIA_COMPAT_MODEL=your-model

# --- Chat channels (enable one or both) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Hermes uses TELEGRAM_ALLOWED_USERS — Ophelia accepts either name
# OPHELIA_TELEGRAM_ENABLED=true

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
# OPHELIA_DISCORD_ENABLED=true
# OPHELIA_PRIMARY_CHANNEL=telegram:123456789
# Consciousness outreach goes to all configured channels.

# --- PC ↔ optional phone body (NOT required on PC/server/VPS) ---
# Default: OPHELIA_ANDROID_ENABLED=false — brain-only Ophelia is fully valid.
# On phone-as-host (Termux): Shizuku — auto-enabled if configured
# From PC/server → separate phone: set ADB target below
# OPHELIA_ANDROID_ENABLED=true
# OPHELIA_ADB_DEVICE=192.168.1.50:5555
# OPHELIA_ADB_ROOT=false

# --- PC vs phone auto-detect overrides ---
# OPHELIA_GAMES=false
# OPHELIA_LISTEN=false

# --- Workstation UI (ophelia ui) ---
OPHELIA_UI_HOST=127.0.0.1
OPHELIA_UI_PORT=8765
OPHELIA_UI_OPEN_BROWSER=true

# --- Web + MCP ---
OPHELIA_WEB_SEARCH=true
# OPHELIA_MCP_CONFIG=~/.ophelia/mcp.json  (see mcp.example.json)

# Consciousness / aliveness
OPHELIA_CONSCIOUSNESS=true
OPHELIA_CONSCIOUSNESS_INTERVAL=60     # seconds between ticks (lower = more alive)
OPHELIA_INITIATIVE_THRESHOLD=0.50     # lower = messages you sooner
OPHELIA_GREET_ON_START=true           # proactive hello when she boots
OPHELIA_MAX_SPONTANEOUS_PER_HOUR=4    # raise for more outreach
# OPHELIA_QUIET_HOURS=23-08           # no outreach 11pm-8am

# Phone body
OPHELIA_ANDROID_ENABLED=true
OPHELIA_VISION_ENABLED=true

# Tier 2
OPHELIA_INNER_LOG=true
OPHELIA_INNER_MIRROR_TELEGRAM=false
OPHELIA_LISTEN=false
OPHELIA_CURATOR=true
OPHELIA_CURATOR_HOURS=6

# Dream / consolidation (offline self-reflection that extracts lessons)
OPHELIA_DREAM=true
OPHELIA_DREAM_HOURS=4

# Games
OPHELIA_GAMES=true
OPHELIA_GAME_SESSION_MINUTES=15
OPHELIA_GAME_MAX_TURNS=40

# HONCHO_API_KEY=
# OPHELIA_VOICE_REPLY=false
