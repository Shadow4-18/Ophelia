# ~/.ophelia/.env — SuperGrok OAuth (no API billing)
OPHELIA_PROVIDER=xai-oauth

# After: hermes auth add xai-oauth  →  ophelia auth import-hermes
# Or: grok login  →  ophelia auth import-grok
# Fallback only: XAI_API_KEY=xai-...

XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Neuro-style continuous mind (NOT Hermes isolated cron)
OPHELIA_CONSCIOUSNESS=true
OPHELIA_CONSCIOUSNESS_INTERVAL=60
OPHELIA_INITIATIVE_THRESHOLD=0.50

# Shizuku body (OpenClaw-style) — run scripts/termux-shizuku-setup.sh
OPHELIA_ANDROID_ENABLED=true
OPHELIA_VISION_ENABLED=true

# Initiative (Tier 1)
OPHELIA_MAX_SPONTANEOUS_PER_HOUR=4
OPHELIA_QUIET_HOURS=23-08

# Tier 2
OPHELIA_INNER_LOG=true
OPHELIA_INNER_MIRROR_TELEGRAM=false
OPHELIA_LISTEN=false
OPHELIA_LISTEN_SECONDS=5
OPHELIA_LISTEN_INTERVAL=45
OPHELIA_CURATOR=true
OPHELIA_CURATOR_HOURS=6

# Games (vision + tap/swipe)
OPHELIA_GAMES=true
OPHELIA_GAME_SESSION_MINUTES=15
OPHELIA_GAME_MAX_TURNS=40

# Honcho (if you used it in Hermes — key from app.honcho.dev)
# HONCHO_API_KEY=
# HONCHO_CONTEXT_TOKENS=2000

# Telegram voice replies (STT always on for voice messages)
# OPHELIA_VOICE_REPLY=false
# XAI_TTS_VOICE=eve

# Future local training/tuning
# OPHELIA_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=your-finetune
