# ~/.ophelia/.env — The Ophelia Project

# --- Provider routing (local-first default) ---
# Values: auto | ollama | xai-oauth | xai | deepseek | openai | compat
OPHELIA_PROVIDER=ollama

# Optional per-role provider overrides (each role can use a different provider)
# OPHELIA_PROVIDER_CHAT=ollama
# OPHELIA_PROVIDER_CONSCIOUSNESS=ollama
# OPHELIA_PROVIDER_VISION=ollama
# OPHELIA_PROVIDER_CURATOR=ollama
# OPHELIA_PROVIDER_IMAGE=xai-oauth
# OPHELIA_PROVIDER_VIDEO=xai-oauth
# OPHELIA_AUTO_LOCAL_CONSCIOUSNESS=true

# Fallback: if the primary provider fails (rate limit, 5xx, network), retry
# on these providers in order before giving up. Only transient errors trigger
# fallback (a 400 bad request is NOT retried). Comma-separated. Empty = off.
# Example: run Grok as primary, DeepSeek V4 Flash as a cheap backup.
# OPHELIA_FALLBACK_PROVIDERS=deepseek,xai-oauth
# OPHELIA_FALLBACK_MODEL=deepseek-v4-flash   (optional: same model on every fallback)

# Optional per-role MODEL overrides (when unset, optional roles inherit chat)
# Ollama per-role:
# OLLAMA_CONSCIOUSNESS_MODEL=llama3.2:1b
# OLLAMA_CURATOR_MODEL=llama3.2:3b
# OLLAMA_VISION_MODEL=openbmb/minicpm-v4.6   (phone-friendly; or moondream)
# OLLAMA_IMAGE_MODEL=flux
# xAI per-role:
# XAI_CONSCIOUSNESS_MODEL=grok-3-mini
# XAI_CURATOR_MODEL=grok-3-mini
# XAI_VISION_MODEL=grok-4
# XAI_IMAGE_MODEL=grok-imagine-image
# XAI_VIDEO_MODEL=grok-imagine-video
# OpenAI per-role:
# OPENAI_CONSCIOUSNESS_MODEL=gpt-4o-mini
# OPENAI_CURATOR_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# DeepSeek per-role (DeepSeek has NO vision/image/video — those auto-route to
# a capable provider: Ollama llava for free local vision, or xAI/OpenAI):
# DEEPSEEK_CONSCIOUSNESS_MODEL=deepseek-v4-flash
# DEEPSEEK_CURATOR_MODEL=deepseek-v4-flash
# Compat per-role:
# OPHELIA_COMPAT_CONSCIOUSNESS_MODEL=local-small
# OPHELIA_COMPAT_CURATOR_MODEL=local-small
# OPHELIA_COMPAT_VISION_MODEL=local-vision

# --- Image generation backends (media-only; set OPHELIA_PROVIDER_IMAGE) ---
# Values: auto | ollama | xai-oauth | xai | openai |
#         pollinations | a1111 | comfyui | fal | replicate | civitai | modelslab
# xAI/OpenAI are CENSORED (refuse explicit prompts). The others are NSFW-capable.
# Pollinations is free and needs no key — image gen works with zero config.
# OPHELIA_PROVIDER_IMAGE=auto

# NSFW content tier. When true, the agent may write explicit prompts and they
# are auto-routed to an uncensored backend (NEVER xAI/OpenAI). When false,
# explicit image requests are refused. The generate_image tool takes an
# `nsfw` flag the model only sets when you explicitly ask for explicit content.
# OPHELIA_IMAGE_NSFW_ALLOWED=false
# OPHELIA_IMAGE_NSFW_PROVIDER=auto   # auto = first configured uncensored backend

# Pollinations (free, no key, lax on NSFW)
# POLLINATIONS_IMAGE_MODEL=flux

# Automatic1111 / SDWebUI (local, uncensored). Run with: --api --listen --port 7860
# A1111_BASE_URL=http://127.0.0.1:7860
# A1111_API_KEY=...            # only if --api-auth is set
# A1111_IMAGE_MODEL=sdxl       # optional checkpoint name
# A1111_STEPS=30
# A1111_SAMPLER=DPM++ 2M Karras
# A1111_CFG_SCALE=7.0

# ComfyUI (local, uncensored). Default txt2img graph; or export a workflow and
# point COMFYUI_WORKFLOW_PATH at it (supports {prompt}/{width}/{height}/{seed}/{model}).
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_IMAGE_MODEL=sdxl     # optional checkpoint filename
# COMFYUI_WORKFLOW_PATH=~/.ophelia/comfyui_workflow.json

# fal.ai (fast cloud; NSFW-tolerant flux/sdxl). https://fal.ai/dashboard/keys
# FAL_API_KEY=...
# FAL_IMAGE_MODEL=fal-ai/fast-sdxl   # or fal-ai/flux/dev, fal-ai/flux/schnell

# Replicate (cloud; many NSFW-allowed community models). https://replicate.com/account/api-tokens
# REPLICATE_API_KEY=...
# REPLICATE_IMAGE_MODEL=stability-ai/sdxl   # owner/model or owner/model:version

# Civitai Orchestration (NSFW checkpoints/LoRAs). https://civitai.com (API keys)
# CIVITAI_API_KEY=...
# CIVITAI_IMAGE_MODEL=        # optional model URN: urn:air:sdxl:checkpoint:civitai:101055@128078
# CIVITAI_BASE_URL=https://orchestration.civitai.com

# ModelsLab (hosted SD; explicit/adult models). https://modelslab.com/dashboard/api-keys
# MODELSLAB_API_KEY=...
# MODELSLAB_IMAGE_MODEL=flux
# MODELSLAB_BASE_URL=https://modelslab.com/api/v6

# --- Ollama (local — recommended) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2:3b
# Vision: phone-friendly options (Termux/S21U) — small + on-device, free:
#   openbmb/minicpm-v4.6  (1.3B, image+video, phone-optimized — recommended)
#   moondream            (1.9B, fast "what's in this photo")
#   openbmb/minicpm-v4   (4.1B, GPT-4V-class accuracy, heavier)
OLLAMA_VISION_MODEL=openbmb/minicpm-v4.6
# Auto-start `ollama serve` when Ophelia needs it and it's down.
# auto = on under Termux (where Ollama isn't a system service), off elsewhere.
# OPHELIA_OLLAMA_AUTOSTART=true
# How long Ollama keeps a model in memory after each call. The default 5m is
# too short for vision: photos are rare, so the model unloads between them and
# every photo cold-loads ~1GB from flash (a 10-25s stall on a phone). 30m keeps
# it warm between uses; -1 keeps it loaded forever (more RAM, fastest).
# OPHELIA_OLLAMA_KEEP_ALIVE=30m

# --- xAI / SuperGrok OAuth (optional cloud fallback) ---
# ophelia auth import-hermes  OR  ophelia auth import-grok
# OPHELIA_PROVIDER=xai-oauth     (SuperGrok OAuth token)
# OPHELIA_PROVIDER=xai           (API key only — does NOT fall back to OAuth,
#                                 because OAuth is a different tier that may
#                                 not access the same models)
# XAI_API_KEY=xai-...
# Aliases (drop in a working config from another Grok bot, e.g. Discord):
#   GROK_API_KEY = XAI_API_KEY
#   GROK_API_URL = XAI_BASE_URL
#   GROK_MODEL   = XAI_MODEL
XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1

# --- OpenAI / compat ---
# OPENAI_API_KEY=sk-...
# OPHELIA_COMPAT_API_KEY=...
# OPHELIA_COMPAT_BASE_URL=http://127.0.0.1:1234/v1
# OPHELIA_COMPAT_MODEL=your-model

# --- DeepSeek (very cheap cloud — great for background roles / fallback) ---
# OpenAI-compatible. Get a key at https://platform.deepseek.com
# deepseek-v4-flash: ~$0.14/1M input, ~$0.28/1M output (1M-token context)
# deepseek-v4-pro:   more capable, higher cost
# OPHELIA_PROVIDER=deepseek
# DEEPSEEK_API_KEY=ds-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash

# --- Chat channels (enable one or both) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Hermes uses TELEGRAM_ALLOWED_USERS — Ophelia accepts either name
# OPHELIA_TELEGRAM_ENABLED=true

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
# OPHELIA_DISCORD_ENABLED=true
# OPHELIA_PRIMARY_CHANNEL=telegram:123456789
# Consciousness outreach goes to all configured channels.

# --- Owner vs guests (multi-user sandboxing) ---
# The ONE user whose conversations shape her memory/personality/soul/evolution.
# Everyone else who messages her is a sandboxed guest: she talks to them with
# her full personality, but the conversation never touches her identity (no
# lessons, no memory writes, no soul/drive/goal changes, no private inner
# thoughts revealed). Channel-style, comma-separated for multiple:
#   OPHELIA_OWNER_ID=telegram:123456789
#   OPHELIA_OWNER_ID=telegram:111,discord:222
# To let others message her, add their IDs to TELEGRAM/DISCORD_ALLOWED_USER_IDS
# above — anyone in that list who isn't the owner becomes a guest. If unset,
# the first allowed user is treated as the owner (backward compatible).
# OPHELIA_OWNER_ID=

# Universal chat log (oversight): every message + media sent to/from her is
# recorded in ~/.ophelia/data/logs/ (SQLite index + organized media folder).
# View with: ophelia logs [--channel telegram:ID] [--media] [--since YYYY-MM-DD]
# OPHELIA_CHAT_LOG=true

# --- PC ↔ optional phone body (NOT required on PC/server/VPS) ---
# Default: OPHELIA_ANDROID_ENABLED=false — brain-only Ophelia is fully valid.
# On phone-as-host (Termux): Shizuku — auto-enabled if configured
# From PC/server → separate phone: set ADB target below
# OPHELIA_ANDROID_ENABLED=true
# OPHELIA_ADB_DEVICE=192.168.1.50:5555
# OPHELIA_ADB_ROOT=false

# --- PC vs phone auto-detect overrides ---
# OPHELIA_GAMES=false
# OPHELIA_LISTEN=false

# --- Workstation UI (ophelia ui) ---
OPHELIA_UI_HOST=127.0.0.1
OPHELIA_UI_PORT=8765
OPHELIA_UI_OPEN_BROWSER=true

# --- Web + MCP ---
# Grok has built-in live search; DeepSeek/OpenAI/Ollama do NOT — so when running
# on those providers Ophelia uses the web_search tool. Pick a backend:
#   auto         use the first API key set below, else DuckDuckGo (default)
#   duckduckgo   free, no key, less reliable (often returns nothing)
#   tavily       AI-focused, reliable (free tier at https://tavily.com)
#   serper       Google results, reliable (https://serper.dev)
#   brave        Brave Search API (https://brave.com/search/api/)
OPHELIA_WEB_SEARCH=true
OPHELIA_WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-...
# SERPER_API_KEY=...
# BRAVE_API_KEY=...
# OPHELIA_MCP_CONFIG=~/.ophelia/mcp.json  (see mcp.example.json)

# Consciousness / aliveness
OPHELIA_CONSCIOUSNESS=true
OPHELIA_CONSCIOUSNESS_INTERVAL=60     # seconds between ticks (lower = more alive)
OPHELIA_TICK_ACTION_COOLDOWN=300      # after she acts/outreaches, skip ticks for N s (0=off)
OPHELIA_TICK_IDLE_NUDGE_ROTATE=true   # vary idle nudge mode (reflect/create/explore/social)
OPHELIA_INITIATIVE_THRESHOLD=0.50     # lower = messages you sooner
OPHELIA_GREET_ON_START=true           # proactive hello when she boots
OPHELIA_MAX_SPONTANEOUS_PER_HOUR=4    # raise for more outreach
# OPHELIA_QUIET_HOURS=23-08           # no outreach 11pm-8am

# Agentic tool loop (per turn)
OPHELIA_MAX_TOOL_ROUNDS=25            # hard cap on tool-call rounds before bailing
OPHELIA_TOOL_LOOP_RESUME=true         # resume unfinished tool chains next turn (unless stuck)
# Raise the cap (e.g. 40) if she's building long artifacts like a from-scratch
# synth engine; the "Continue" button in Telegram lets you extend a capped turn
# with one tap.

# Phone body
OPHELIA_ANDROID_ENABLED=true
OPHELIA_VISION_ENABLED=true
# Draw a native-pixel coordinate grid on screenshots sent to vision so tap
# coordinates come back in `input tap`'s native space (not the model's resized
# image space). Calibrate with: ophelia phone calibrate
OPHELIA_VISION_GRID=true

# Tier 2
OPHELIA_INNER_LOG=true
OPHELIA_INNER_MIRROR_TELEGRAM=false
OPHELIA_LISTEN=false
OPHELIA_CURATOR=true
OPHELIA_CURATOR_HOURS=6

# Dream / consolidation (offline self-reflection that extracts lessons)
OPHELIA_DREAM=true
OPHELIA_DREAM_HOURS=4

# Games
OPHELIA_GAMES=true
OPHELIA_GAME_SESSION_MINUTES=15
OPHELIA_GAME_MAX_TURNS=40

# HONCHO_API_KEY=
# OPHELIA_VOICE_REPLY=false
