# ~/.ophelia/.env

# --- Provider routing (auto picks best available credentials) ---
# Values: auto | xai-oauth | xai | ollama | openai | compat
OPHELIA_PROVIDER=auto

# Optional per-role overrides (hybrid: local consciousness + cloud chat)
# OPHELIA_PROVIDER_CHAT=xai-oauth
# OPHELIA_PROVIDER_CONSCIOUSNESS=ollama
# OPHELIA_PROVIDER_VISION=xai-oauth
# OPHELIA_PROVIDER_CURATOR=ollama
# OPHELIA_AUTO_LOCAL_CONSCIOUSNESS=true

# --- xAI / SuperGrok OAuth (phone or PC) ---
# ophelia auth import-hermes  OR  ophelia auth import-grok
# XAI_API_KEY=xai-...          # fallback: OPHELIA_PROVIDER=xai
XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1
# XAI_VISION_MODEL=grok-4

# --- OpenAI API ---
# OPHELIA_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# --- OpenAI-compatible (OpenRouter, LM Studio, vLLM, etc.) ---
# OPHELIA_PROVIDER=compat
# OPHELIA_COMPAT_API_KEY=...
# OPHELIA_COMPAT_BASE_URL=http://127.0.0.1:1234/v1
# OPHELIA_COMPAT_MODEL=your-model
# OPHELIA_COMPAT_VISION_MODEL=your-vision-model

# --- Ollama (local) ---
# OPHELIA_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava

# --- Telegram (required for ophelia run; optional on PC for ophelia chat / ui) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# --- PC vs phone (auto-detected; override if needed) ---
# OPHELIA_ANDROID_ENABLED=false
# OPHELIA_GAMES=false
# OPHELIA_LISTEN=false

# --- Workstation UI (ophelia ui) ---
OPHELIA_UI_HOST=127.0.0.1
OPHELIA_UI_PORT=8765
OPHELIA_UI_OPEN_BROWSER=true

# Consciousness
OPHELIA_CONSCIOUSNESS=true
OPHELIA_CONSCIOUSNESS_INTERVAL=60
OPHELIA_INITIATIVE_THRESHOLD=0.50

# Phone body (Termux + Shizuku)
OPHELIA_ANDROID_ENABLED=true
OPHELIA_VISION_ENABLED=true

OPHELIA_MAX_SPONTANEOUS_PER_HOUR=4
OPHELIA_QUIET_HOURS=23-08

# Tier 2
OPHELIA_INNER_LOG=true
OPHELIA_INNER_MIRROR_TELEGRAM=false
OPHELIA_LISTEN=false
OPHELIA_LISTEN_SECONDS=5
OPHELIA_LISTEN_INTERVAL=45
OPHELIA_CURATOR=true
OPHELIA_CURATOR_HOURS=6

# Games
OPHELIA_GAMES=true
OPHELIA_GAME_SESSION_MINUTES=15
OPHELIA_GAME_MAX_TURNS=40

# HONCHO_API_KEY=
# OPHELIA_VOICE_REPLY=false
# XAI_TTS_VOICE=eve
